{
  "name": "strapi-plugin-publish-confirmation",
  "version": "1.0.0",
  "description": "Adds a confirmation dialog before publishing content in Strapi v5",
  "strapi": {
    "kind": "plugin",
    "name": "publish-confirmation",
    "displayName": "Publish Confirmation",
    "description": "Intercepts the Publish button in the Content Manager and asks for confirmation before publishing."
  },
  "keywords": [
    "strapi",
    "strapi-plugin",
    "strapi-v5",
    "publish",
    "confirmation",
    "dialog",
    "content-manager"
  ],
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "types": "./dist/admin/src/index.d.ts",
      "source": "./admin/src/index.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "types": "./dist/server/src/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "strapi-plugin build --minify",
    "test": "vitest run",
    "test:watch": "vitest",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify"
  },
  "devDependencies": {
    "@strapi/admin": "^5.0.0",
    "@strapi/sdk-plugin": "^5.3.2",
    "@strapi/strapi": "^5.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.0.0",
    "jsdom": "^29.1.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.1.9"
  },
  "peerDependencies": {
    "@strapi/admin": "^5.0.0",
    "@strapi/strapi": "^5.0.0",
    "react": "^18.0.0",
    "react-intl": "^6.0.0 || ^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=11.0.0"
  },
  "license": "MIT"
}
